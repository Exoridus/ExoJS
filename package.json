{
  "name": "exo-js-core",
  "description": "A lightweight, flexibile and powerful multimedia framework.",
  "version": "1.0.20",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/exo.js",
  "module": "dist/exo.esm.js",
  "browser": "dist/exo.bundle.js",
  "types": "dist/exo.d.ts",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && rollup -c",
    "build:watch": "rollup -cw",
    "build:declarations": "node node_modules/typescript-3-9/bin/tsc -p tsconfig.declaration.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "prepare": "husky",
    "commit": "gitmoji -c"
  },
  "license": "MIT",
  "homepage": "https://github.com/Exoridus/ExoJS",
  "repository": {
    "type": "git",
    "url": "https://github.com/Exoridus/ExoJS.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-commonjs": "^14.0.0",
    "@rollup/plugin-node-resolve": "^8.0.1",
    "@types/css-font-loading-module": "0.0.4",
    "@types/earcut": "^2.1.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^13.13.10",
    "eslint": "^9.39.1",
    "gitmoji-cli": "^9.7.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-util": "^29.7.0",
    "jiti": "^2.6.1",
    "rimraf": "^6.1.0",
    "rollup": "^2.15.0",
    "rollup-plugin-cleaner": "^1.0.0",
    "rollup-plugin-string": "^3.0.0",
    "rollup-plugin-typescript2": "^0.27.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-3-9": "npm:typescript@3.9.10",
    "typescript-eslint": "^8.48.0"
  },
  "dependencies": {
    "earcut": "^2.2.2"
  }
}
