{
  "name": "@codexo/exojs",
  "description": "A lightweight, flexible and powerful multimedia framework.",
  "version": "0.4.0",
  "files": [
    "dist/esm/",
    "dist/exo.esm.js",
    "dist/exo.esm.js.map",
    "dist/exo.esm.min.js",
    "dist/exo.esm.min.js.map",
    "dist/exo.global.js",
    "dist/exo.global.js.map",
    "dist/exo.global.min.js",
    "dist/exo.global.min.js.map",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/exo.esm.js",
  "module": "./dist/esm/index.js",
  "browser": "./dist/exo.esm.js",
  "types": "./dist/esm/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsx node_modules/rollup/dist/bin/rollup -c",
    "build:watch": "tsx node_modules/rollup/dist/bin/rollup -cw",
    "verify:exports": "node ./scripts/verify-exports.mjs",
    "verify:package": "npm run build && npm run verify:exports && npm pack --dry-run",
    "verify:release": "npm run typecheck && npm run lint && npm test && npm run verify:package",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "perf:benchmark": "tsx test/perf/rendering-benchmark.ts",
    "prepare": "husky",
    "commit": "gitmoji -c"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/Exoridus/ExoJS",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Exoridus/ExoJS.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/css-font-loading-module": "0.0.14",
    "@types/earcut": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@webgpu/types": "^0.1.69",
    "eslint": "^10.2.1",
    "gitmoji-cli": "^9.7.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jiti": "^2.6.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "rollup-plugin-string": "^3.0.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "earcut": "^3.0.2"
  },
  "peerDependencies": {
    "@dimforge/rapier2d-compat": "*"
  },
  "peerDependenciesMeta": {
    "@dimforge/rapier2d-compat": {
      "optional": true
    }
  }
}
