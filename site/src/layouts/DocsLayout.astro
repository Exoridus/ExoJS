---
import AppShell from './AppShell.astro';

interface Props {
    title: string;
    description?: string;
}

const { title, description = 'ExoJS documentation' } = Astro.props;
const hasSidebar = Astro.slots.has('sidebar');
---

<AppShell title={title} description={description}>
    <section class:list={['docs-shell', !hasSidebar && 'docs-shell--full']}>
        <aside class="docs-shell__sidebar"><slot name="sidebar" /></aside>
        <article class="docs-shell__content"><slot /></article>
    </section>
</AppShell>

<style>
    .docs-shell {
        width: min(1280px, 100% - 2rem);
        margin: 1.25rem auto 2rem;
        display: grid;
        gap: 1rem;
        grid-template-columns: 300px minmax(0, 1fr);
    }

    .docs-shell--full {
        grid-template-columns: minmax(0, 1fr);
    }

    .docs-shell--full .docs-shell__sidebar {
        display: none;
    }

    .docs-shell__content {
        border: 1px solid var(--line-soft);
        border-radius: var(--r-4);
        padding: 1.25rem;
        background: var(--bg-elevated);
        min-width: 0;
    }

    @media (max-width: 960px) {
        .docs-shell {
            grid-template-columns: 1fr;
            width: min(1280px, 100% - 1rem);
        }
    }
</style>
