---
interface Props {
    title: string;
    description?: string;
}

const { title, description = 'ExoJS documentation' } = Astro.props;
const hasSidebar = Astro.slots.has('sidebar');
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta name="description" content={description} />
    </head>
    <body>
        <header class="top-nav">
            <a href={`${import.meta.env.BASE_URL}`}>ExoJS</a>
            <nav>
                <a href={`${import.meta.env.BASE_URL}guide/`}>Guide</a>
                <a href={`${import.meta.env.BASE_URL}playground/`}>Playground</a>
                <a href={`${import.meta.env.BASE_URL}api/`}>API</a>
            </nav>
        </header>
        <main class:list={['docs-shell', !hasSidebar && 'docs-shell--full']}>
            <div class="docs-shell__sidebar"><slot name="sidebar" /></div>
            <article class="docs-shell__content"><slot /></article>
        </main>
    </body>
</html>

<style is:global>
    :root {
        color-scheme: light;
        font-family: 'Inter', 'Segoe UI', sans-serif;
        background: #f1f5f9;
        color: #0f172a;
    }

    body {
        margin: 0;
        background:
            radial-gradient(circle at 0% 0%, rgba(16, 185, 129, 0.14), transparent 40%),
            radial-gradient(circle at 100% 100%, rgba(59, 130, 246, 0.14), transparent 45%),
            #f1f5f9;
    }

    .top-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.8rem 1.2rem;
        border-bottom: 1px solid rgba(15, 23, 42, 0.16);
        backdrop-filter: blur(8px);
    }

    .top-nav > a {
        font-weight: 700;
        text-decoration: none;
        color: #0f172a;
    }

    .top-nav nav {
        display: flex;
        gap: 0.9rem;
    }

    .top-nav nav a {
        text-decoration: none;
        color: #0f172a;
    }

    .docs-shell {
        width: min(1220px, 100% - 2rem);
        margin: 1rem auto 2rem;
        display: grid;
        gap: 1rem;
        grid-template-columns: 280px minmax(0, 1fr);
    }

    .docs-shell--full {
        grid-template-columns: minmax(0, 1fr);
    }

    .docs-shell--full .docs-shell__sidebar {
        display: none;
    }

    .docs-shell__content {
        border: 1px solid rgba(148, 163, 184, 0.35);
        border-radius: 14px;
        padding: 1.25rem;
        background: #ffffff;
        min-width: 0;
    }

    @media (max-width: 960px) {
        .docs-shell {
            grid-template-columns: 1fr;
        }
    }
</style>
