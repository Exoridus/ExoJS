---
import { GUIDE_PARTS } from '../../../../lib/guide-structure';

export function getStaticPaths() {
    return GUIDE_PARTS.map(part => ({ params: { part: part.slug } }));
}

const partSlug = (Astro.params as Record<string, string | undefined>).part ?? '';
const part = GUIDE_PARTS.find(entry => entry.slug === partSlug);

if (!part) {
    throw new Error(`Unknown guide part: ${partSlug}`);
}

const firstChapter = part.chapters[0];
if (!firstChapter) {
    throw new Error(`Guide part has no chapters: ${partSlug}`);
}

const targetHref = `${import.meta.env.BASE_URL}en/guide/${part.slug}/${firstChapter.slug}/`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{part.title} | ExoJS Guide</title>
        <script is:inline define:vars={{ targetHref }}>
            window.location.replace(targetHref);
        </script>
        <noscript>
            <meta http-equiv="refresh" content={`0;url=${targetHref}`} />
        </noscript>
    </head>
    <body>
        <p>Redirecting to <a href={targetHref}>{firstChapter.title}</a>...</p>
    </body>
</html>
