---
import GuideChapterPage from '../../../../../components/pages/GuideChapterPage.astro';
import { GUIDE_PARTS } from '../../../../../lib/guide-structure';

export function getStaticPaths() {
    return GUIDE_PARTS.flatMap(part =>
        part.chapters.map(chapter => ({
            params: {
                part: part.slug,
                chapter: chapter.slug,
            },
        })),
    );
}

const partSlug = (Astro.params as Record<string, string | undefined>).part ?? '';
const chapterSlug = (Astro.params as Record<string, string | undefined>).chapter ?? '';
---

<GuideChapterPage locale="de" partSlug={partSlug} chapterSlug={chapterSlug} />
