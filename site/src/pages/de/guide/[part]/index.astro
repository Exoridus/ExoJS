---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import TranslationNotice from '../../../../components/TranslationNotice.astro';
import { GUIDE_PARTS } from '../../../../lib/guide-structure';

export function getStaticPaths() {
    return GUIDE_PARTS.map(part => ({ params: { part: part.slug } }));
}

const partSlug = (Astro.params as Record<string, string | undefined>).part ?? '';
const part = GUIDE_PARTS.find(entry => entry.slug === partSlug);

if (!part) {
    throw new Error(`Unknown guide part: ${partSlug}`);
}
---

<DocsLayout title={`${part.title} (DE)`} description="German localization placeholder for this guide part.">
    <section class="de-guide-part">
        <h1>{part.title}</h1>
        <p>This part is available in English only at the moment.</p>
        <TranslationNotice englishHref={`${import.meta.env.BASE_URL}en/guide/${part.slug}/`} />
    </section>
</DocsLayout>

<style>
    .de-guide-part {
        display: grid;
        gap: 0.9rem;
    }

    .de-guide-part h1 {
        margin: 0;
        font-size: clamp(1.6rem, 3.4vw, 2.3rem);
    }

    .de-guide-part p {
        margin: 0;
        color: var(--fg-muted);
        max-width: 64ch;
    }
</style>
