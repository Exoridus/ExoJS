---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import DocsSidebar from '../../../components/DocsSidebar.astro';
import { GUIDE_PARTS } from '../../../lib/guide-structure';

export function getStaticPaths() {
    return GUIDE_PARTS.map(part => ({ params: { part: part.slug } }));
}

const partSlug = (Astro.params as Record<string, string | undefined>).part ?? '';
const part = GUIDE_PARTS.find(entry => entry.slug === partSlug);

if (!part) {
    throw new Error(`Unknown guide part: ${partSlug}`);
}

const sidebarParts = GUIDE_PARTS.map(entry => ({
    slug: entry.slug,
    title: entry.title,
    href: `${import.meta.env.BASE_URL}guide/${entry.slug}/`,
    chapters: entry.chapters.map(chapter => ({
        slug: chapter.slug,
        title: chapter.title,
        href: `${import.meta.env.BASE_URL}guide/${entry.slug}/${chapter.slug}/`,
    })),
}));
---

<DocsLayout title={`${part.title} | ExoJS Guide`} description={part.description}>
    <DocsSidebar slot="sidebar" parts={sidebarParts} />

    <h1>{part.title}</h1>
    <p>{part.description}</p>

    <section class="chapter-list">
        {part.chapters.map(chapter => (
            <article>
                <h2>
                    <a href={`${import.meta.env.BASE_URL}guide/${part.slug}/${chapter.slug}/`}>{chapter.title}</a>
                </h2>
                <p>{chapter.description}</p>
                <p>{chapter.examples.length} examples</p>
            </article>
        ))}
    </section>
</DocsLayout>

<style>
    .chapter-list {
        display: grid;
        gap: 0.75rem;
    }

    .chapter-list article {
        border: 1px solid rgba(148, 163, 184, 0.35);
        border-radius: 12px;
        padding: 0.9rem;
        background: rgba(255, 255, 255, 0.78);
    }

    .chapter-list h2 {
        margin: 0 0 0.4rem;
        font-size: 1rem;
    }

    .chapter-list h2 a {
        color: inherit;
        text-decoration: none;
    }

    .chapter-list p {
        margin: 0.35rem 0;
    }
</style>
