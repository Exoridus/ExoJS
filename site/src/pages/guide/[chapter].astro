---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import DocsSidebar from '../../components/DocsSidebar.astro';
import { CHAPTERS } from '../../lib/chapters';

export async function getStaticPaths() {
    const guideEntries = await getCollection('guide');
    return guideEntries.map((entry: CollectionEntry<'guide'>) => ({ params: { chapter: entry.data.chapter } }));
}

const chapter = (Astro.params as Record<string, string | undefined>).chapter ?? '';
const guideEntries = await getCollection('guide');
const entry = guideEntries.find((item: CollectionEntry<'guide'>) => item.data.chapter === chapter);
if (!entry) {
    throw new Error(`Unknown guide chapter: ${chapter}`);
}
const { Content } = await render(entry);
const sidebarGroups = [
    {
        title: 'Guide Chapters',
        items: CHAPTERS.map(chapter => ({
            href: `${import.meta.env.BASE_URL}guide/${chapter.slug}/`,
            label: `${chapter.order}. ${chapter.title}`,
        })),
    },
];
---

<DocsLayout title={`${entry.data.title} | ExoJS Guide`} description={entry.data.description}>
    <DocsSidebar slot="sidebar" groups={sidebarGroups} />
    <Content />
</DocsLayout>
