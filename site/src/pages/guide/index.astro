---
import DocsLayout from '../../layouts/DocsLayout.astro';
import DocsSidebar from '../../components/DocsSidebar.astro';
import { GUIDE_PARTS } from '../../lib/guide-structure';

const chapterCount = GUIDE_PARTS.reduce((sum, part) => sum + part.chapters.length, 0);
const exampleCount = GUIDE_PARTS.reduce((sum, part) => sum + part.chapters.reduce((inner, chapter) => inner + chapter.examples.length, 0), 0);
const sidebarParts = GUIDE_PARTS.map(part => ({
    slug: part.slug,
    title: part.title,
    href: `${import.meta.env.BASE_URL}guide/${part.slug}/`,
    chapters: part.chapters.map(chapter => ({
        slug: chapter.slug,
        title: chapter.title,
        href: `${import.meta.env.BASE_URL}guide/${part.slug}/${chapter.slug}/`,
    })),
}));
---

<DocsLayout title="ExoJS Guide" description="Structured ExoJS guide from introduction to advanced recipes.">
    <DocsSidebar slot="sidebar" parts={sidebarParts} />

    <section class="overview-hero">
        <h1>Guide</h1>
        <p>Start with Introduction if you are new to ExoJS. Jump into Core Concepts when you need the runtime model, and use Recipes when you want production-oriented patterns.</p>
        <div class="overview-stats">
            <span>{chapterCount} chapters</span>
            <span>{exampleCount} example links</span>
            <span>Estimated read path: 3 to 5 sessions</span>
        </div>
    </section>

    <section class="parts-grid">
        {GUIDE_PARTS.map(part => (
            <article>
                <h2>
                    <a href={`${import.meta.env.BASE_URL}guide/${part.slug}/`}>{part.title}</a>
                </h2>
                <p>{part.description}</p>
                <p>{part.chapters.length} sub-chapters</p>
            </article>
        ))}
    </section>
</DocsLayout>

<style>
    .overview-hero {
        border: 1px solid var(--line-soft);
        border-radius: var(--r-4);
        padding: 1rem;
        background: var(--bg-panel);
        margin-bottom: 0.95rem;
    }

    .overview-hero h1 {
        margin: 0;
        font-size: clamp(1.8rem, 3.6vw, 2.4rem);
    }

    .overview-hero p {
        margin: 0.65rem 0 0;
        color: var(--fg-muted);
        max-width: 68ch;
    }

    .overview-stats {
        margin-top: 0.85rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .overview-stats span {
        border: 1px solid var(--line-soft);
        border-radius: var(--r-pill);
        padding: 0.25rem 0.6rem;
        background: color-mix(in oklab, var(--bg-elevated), transparent 10%);
        font-size: 0.8rem;
    }

    .parts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.75rem;
    }

    .parts-grid article {
        border: 1px solid var(--line-soft);
        border-radius: var(--r-4);
        padding: 0.9rem;
        background: color-mix(in oklab, var(--bg-elevated), transparent 8%);
    }

    .parts-grid h2 {
        margin: 0 0 0.45rem;
        font-size: 1rem;
    }

    .parts-grid h2 a {
        color: inherit;
        text-decoration: none;
    }

    .parts-grid p {
        margin: 0.35rem 0;
        color: var(--fg-muted);
    }
</style>
