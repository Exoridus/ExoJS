              "kind": "punctuation"
            },
            {
              "text": "OverSampleType",
              "kind": "type"
            }
          ],
          "params": [],
          "returnType": null,
          "description": "Oversampling mode applied by the WaveShaperNode. Higher oversampling reduces aliasing artifacts at the cost of extra CPU. One of 'none', '2x', or '4x'. Default '2x'."
        },
        {
          "name": "tone",
