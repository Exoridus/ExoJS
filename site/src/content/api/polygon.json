{
  "title": "Polygon",
  "description": "Mutable convex polygon defined by a world-space offset `(x, y)` and an array of local-space vertex Vectors. Implements ShapeLike with full SAT collision response. Edge vectors are recomputed whenever `setPoints` is called; normals are cached lazily and invalidated on any positional or point mutation. `Polygon.temp` is a shared scratch instance.",
  "symbol": "Polygon",
  "kind": "class",
  "subsystem": "math",
  "importPath": "@codexo/exojs",
  "tier": "stable",
