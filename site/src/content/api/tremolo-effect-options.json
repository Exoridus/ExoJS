          "params": [],
          "returnType": null,
          "description": "When true the same LFO also drives a StereoPannerNode.pan (amplitude = depth), sweeping the signal left and right in synchrony with the tremolo pulsing. This option is read-only after construction. Default false."
        },
        {
          "name": "depth",
          "signature": "depth?: number",
          "signatureTokens": [
            {
              "text": "depth",
              "kind": "name"
            },
