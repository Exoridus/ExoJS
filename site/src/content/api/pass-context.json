{
  "title": "PassContext",
  "description": "Pass-scoped DrawContext: the active render target and view for a CallbackRenderPass callback. `clear`/`render`/`renderTo` route through the owning RenderingContext (and its pass coordinator), so they act on THIS pass's target and never reset the active view or leak onto another target. Default view for `render`/`draw*` is the pass view — not the world view — so a callback inside an off-screen redirect renders correctly without passing `{ view }` explicitly. Use backend only for raw draws or GPU state; switching target / view / clear through it bypasses the coordinator (the leak this type prevents).",
  "symbol": "PassContext",
  "kind": "class",
  "subsystem": "rendering",
  "importPath": "@codexo/exojs",
  "tier": "advanced",
  "memberCount": 9,
