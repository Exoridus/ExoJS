              "text": "number",
              "kind": "keyword"
            }
          ],
          "params": [],
          "returnType": null,
          "description": "Maximum number of new chunk loads issued per ChunkStreamer.update call, after the very first call (which loads the entire initial wanted set unbudgeted, so the starting view never pops in). Default 8."
        },
        {
          "name": "unloadRadius",
          "signature": "unloadRadius?: number",
          "signatureTokens": [
            {
              "text": "unloadRadius",
              "kind": "name"
