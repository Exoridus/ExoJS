{
  "title": "Scene",
  "description": "A scene's lifecycle host. Subclass to define scene behavior: class GameScene extends Scene { override init(loader: Loader): void { ... } override update(delta: Time): void { ... } override draw(context: RenderingContext): void { ... } } app.start(new GameScene()); For one-off scenes, an anonymous subclass works just as well: app.start(new class extends Scene { override update(delta) { ... } override draw(context) { ... } });",
