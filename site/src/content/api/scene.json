          "params": [],
          "returnType": null,
          "description": "Scene-bound tween registry. Tweens created via this.tweens.create(...) are automatically stopped when the scene is destroyed — no manual cleanup required. Throws if accessed before the scene is attached to an Application."
        },
        {
          "name": "ui",
          "signature": "ui: UIRoot",
          "signatureTokens": [
            {
              "text": "ui",
              "kind": "name"
            },
            {
