{
  "title": "Drag",
  "description": "Exponential velocity damping. Each frame multiplies every live particle's velocity by `(1 - drag * dt)`, simulating linear air resistance. `drag = 0` is no damping; `drag = 1` halves velocity in ~1 second; higher values slow particles faster. Negative values accelerate (don't do that unless you mean it). GPU-eligible.",
  "symbol": "Drag",
  "kind": "class",
  "subsystem": "particles",
