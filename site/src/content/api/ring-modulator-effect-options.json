            {
              "text": "OscillatorType",
              "kind": "type"
            }
          ],
          "params": [],
          "returnType": null,
          "description": "Carrier oscillator waveform shape. Default 'sine'. Any OscillatorType is accepted ('sine', 'square', 'sawtooth', 'triangle'). Non-sine shapes introduce additional harmonic content into both sidebands."
        },
        {
          "name": "wet",
