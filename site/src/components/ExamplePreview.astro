---
import type { Capability } from '../lib/examples-catalog';
import { getExamplesForChapter } from '../lib/examples-catalog';
import { getExampleSource } from '../lib/example-sources';

interface Props {
    chapter: string;
    slug: string;
}

const CAPABILITY_LABELS: Record<Capability, string> = {
    webgl2: 'WebGL2',
    webgpu: 'WebGPU',
    pointer: 'Pointer',
    keyboard: 'Keyboard',
    gamepad: 'Gamepad',
    touch: 'Touch',
    audio: 'Audio',
    fullscreen: 'Fullscreen',
    vibration: 'Vibration',
    offscreenCanvas: 'OffscreenCanvas',
    webWorkers: 'Workers',
};

const { chapter, slug } = Astro.props;
const example = getExamplesForChapter(chapter).find(entry => entry.slug === slug);
const sourceCode = getExampleSource(chapter, slug);
const exampleTitle = example?.title ?? slug;
const capabilities = example?.capabilities ?? [];
const capabilitiesAttr = JSON.stringify(capabilities);
const sourceHref = `${import.meta.env.BASE_URL}examples/${chapter}/${slug}.js`;
const locale = Astro.currentLocale === 'de' ? 'de' : 'en';
---

<section class="example-preview">
    <header class="example-preview__header">
        <h3>{exampleTitle}</h3>
        <div class="example-preview__actions">
            <a class="example-preview__action" href={`${import.meta.env.BASE_URL}${locale}/playground/?example=${chapter}/${slug}`}>Open in Playground</a>
            <a class="example-preview__action example-preview__action--quiet" href={sourceHref}>View source</a>
        </div>
    </header>
    {
        capabilities.length > 0 && (
            <ul class="example-preview__caps" aria-label="Required browser capabilities">
                {capabilities.map(cap => (
                    <li class="example-preview__cap" title={`Required: ${cap}`}>
                        {CAPABILITY_LABELS[cap]}
                    </li>
                ))}
            </ul>
        )
    }
    <div class="example-preview__live">
        <guide-example-preview chapter={chapter} slug={slug} title={exampleTitle} sourcecode={sourceCode} capabilities={capabilitiesAttr}></guide-example-preview>
    </div>
</section>

<script>
    import './GuideExamplePreview';
</script>

<style>
    .example-preview {
        border: 1px solid var(--line-soft);
        border-radius: var(--r-4);
        padding: 1rem;
        margin: 1rem 0 1.4rem;
        background: var(--bg-panel);
    }

    .example-preview__header {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.8rem;
    }

    .example-preview__header h3 {
        margin: 0;
        font-size: 1rem;
        color: var(--fg);
    }

    .example-preview__actions {
        display: inline-flex;
        gap: 0.5rem;
    }

    .example-preview__action {
        font-size: 0.82rem;
        text-decoration: none;
        border-radius: var(--r-2);
        padding: 0.4rem 0.65rem;
        border: 1px solid var(--accent-line);
        background: var(--accent-soft);
        color: var(--fg);
    }

    .example-preview__action--quiet {
        border-color: var(--line-soft);
        background: transparent;
        color: var(--fg-muted);
    }

    .example-preview__live {
        margin-top: 0.35rem;
    }

    .example-preview__caps {
        list-style: none;
        margin: 0 0 0.65rem;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .example-preview__cap {
        font-size: 0.72rem;
        font-family: var(--f-mono);
        padding: 0.18rem 0.55rem;
        border-radius: 999px;
        background: var(--accent-soft);
        border: 1px solid var(--accent-line);
        color: var(--fg);
    }
</style>
