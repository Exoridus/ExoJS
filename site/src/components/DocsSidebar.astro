---
interface SidebarGroup {
    title: string;
    items: Array<{
        href: string;
        label: string;
    }>;
}

interface Props {
    parts?: Array<{
        slug: string;
        title: string;
        href: string;
        chapters: Array<{
            slug: string;
            title: string;
            href: string;
        }>;
    }>;
    groups?: Array<SidebarGroup>;
}

const { parts = [], groups = [] } = Astro.props;
const currentPath = Astro.url.pathname;
---

<aside class="docs-sidebar">
    {
        groups.length > 0 &&
            groups.map(group => (
                <section>
                    <h2>{group.title}</h2>
                    <ul>
                        {group.items.map(item => (
                            <li>
                                <a href={item.href} class={currentPath === item.href ? 'active' : ''}>
                                    {item.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                </section>
            ))
    }
    {parts.map(part => (
        <details open={currentPath.startsWith(part.href)}>
            <summary>
                <a href={part.href} class={currentPath === part.href ? 'active' : ''}>{part.title}</a>
            </summary>
            <ul>
                {part.chapters.map(chapter => (
                    <li>
                        <a href={chapter.href} class={currentPath === chapter.href ? 'active' : ''}>
                            {chapter.title}
                        </a>
                    </li>
                ))}
            </ul>
        </details>
    ))}
</aside>

<style>
    .docs-sidebar {
        position: sticky;
        top: 1rem;
        max-height: calc(100vh - 2rem);
        overflow: auto;
        border: 1px solid rgba(148, 163, 184, 0.3);
        border-radius: 12px;
        background: #f8fafc;
        padding: 0.85rem;
    }

    .docs-sidebar details + details {
        margin-top: 0.9rem;
    }

    .docs-sidebar section + section {
        margin-top: 0.9rem;
    }

    .docs-sidebar h2 {
        margin: 0 0 0.5rem;
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #475569;
    }

    .docs-sidebar details {
        border: 1px solid rgba(148, 163, 184, 0.25);
        border-radius: 10px;
        padding: 0.35rem 0.45rem;
        background: rgba(255, 255, 255, 0.72);
    }

    .docs-sidebar summary {
        cursor: pointer;
        list-style: none;
    }

    .docs-sidebar summary::-webkit-details-marker {
        display: none;
    }

    .docs-sidebar summary a {
        display: inline-block;
        width: 100%;
        border-radius: 8px;
        padding: 0.3rem 0.45rem;
        text-decoration: none;
        font-size: 0.85rem;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: #0f172a;
        font-weight: 600;
    }

    .docs-sidebar ul {
        list-style: none;
        margin: 0.35rem 0 0;
        padding: 0;
        display: grid;
        gap: 0.3rem;
    }

    .docs-sidebar a {
        display: block;
        border-radius: 8px;
        padding: 0.36rem 0.5rem;
        font-size: 0.85rem;
        color: #0f172a;
        text-decoration: none;
    }

    .docs-sidebar a.active {
        background: #0f172a;
        color: #f8fafc;
    }
</style>
