---
interface SidebarItem {
    href: string;
    label: string;
}

interface SidebarGroup {
    title: string;
    items: Array<SidebarItem>;
}

interface Props {
    groups: Array<SidebarGroup>;
}

const { groups } = Astro.props;
const currentPath = Astro.url.pathname;
---

<aside class="docs-sidebar">
    {groups.map(group => (
        <section>
            <h2>{group.title}</h2>
            <ul>
                {group.items.map(item => (
                    <li>
                        <a href={item.href} class={currentPath === item.href ? 'active' : ''}>{item.label}</a>
                    </li>
                ))}
            </ul>
        </section>
    ))}
</aside>

<style>
    .docs-sidebar {
        position: sticky;
        top: 1rem;
        max-height: calc(100vh - 2rem);
        overflow: auto;
        border: 1px solid rgba(148, 163, 184, 0.3);
        border-radius: 12px;
        background: #f8fafc;
        padding: 0.85rem;
    }

    .docs-sidebar section + section {
        margin-top: 0.9rem;
    }

    .docs-sidebar h2 {
        margin: 0 0 0.5rem;
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #475569;
    }

    .docs-sidebar ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.3rem;
    }

    .docs-sidebar a {
        display: block;
        border-radius: 8px;
        padding: 0.36rem 0.5rem;
        font-size: 0.9rem;
        color: #0f172a;
        text-decoration: none;
    }

    .docs-sidebar a.active {
        background: #0f172a;
        color: #f8fafc;
    }
</style>
