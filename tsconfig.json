{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "lib": ["es2020", "dom", "dom.iterable"],
    "outDir": "dist",
    "paths": {
      "audio/*": ["./src/audio/*"],
      "core/*": ["./src/core/*"],
      "input/*": ["./src/input/*"],
      "math/*": ["./src/math/*"],
      "particles/*": ["./src/particles/*"],
      "physics/*": ["./src/physics/*"],
      "rendering/*": ["./src/rendering/*"],
      "resources/*": ["./src/resources/*"],
      "vendor/*": ["./src/vendor/*"]
    },
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.spec.ts"
  ]
}
