{
  "name": "@codexo/exojs-react",
  "version": "0.14.0",
  "description": "React integration for ExoJS.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Exoridus/ExoJS.git",
    "directory": "packages/exojs-react"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": ["src/", "README.md", "LICENSE"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "peerDependencies": {
    "@codexo/exojs": "0.14.x",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codexo/exojs": "workspace:*",
    "@codexo/exojs-config": "workspace:*",
    "@types/react": "^18.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
