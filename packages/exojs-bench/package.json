{
  "name": "@codexo/exojs-bench",
  "version": "0.0.0",
  "description": "Private, reproducible cross-library rendering benchmark harness for ExoJS. Not published; run with `pnpm --filter @codexo/exojs-bench bench`.",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "tsx src/run.ts",
    "perf:baseline": "tsx src/run.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run --root ../.. --project=exojs-bench"
  },
  "devDependencies": {
    "@codexo/exojs": "workspace:*",
    "@codexo/exojs-config": "workspace:*",
    "@types/node": "^25.6.0",
    "@webgpu/types": "^0.1.69",
    "pixi.js": "8.19.0",
    "playwright": "^1.50.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.7"
  },
  "license": "MIT"
}
