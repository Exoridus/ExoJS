# === Project artifacts ===
node_modules
dist/*
packages/*/dist
coverage
__screenshots__
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tgz
test/perf/results/*.json
test/perf/results/*.md

# Local scratch / ad-hoc debug artifacts (probe scripts, screenshot montages).
codexo-probe*
codexo-montage*
codexo-bg-*

# === Dotfiles: blanket-ignore, then allowlist tracked ones ===
# Anything starting with `.` is ignored by default. Protects against tool
# caches (.rollup.cache, .turbo, .next, .astro, …), IDE folders (.idea,
# .vscode, …), env files (.env, .env.local, …), AI/agent state (.claude,
# .codex, …), and any future tool that drops a dotfile we haven't seen yet.
.*

# Allowlist tracked dotfile configs (matched at any depth — a single rule
# covers `.prettierrc`, `examples/.prettierrc`, `site/.prettierrc`, etc.).
!.codecov.yml
!.editorconfig
!.eslintignore
!.eslintrc.json
!.gitattributes
!.gitignore
!.gitkeep
!.prettierignore
!.prettierrc
!.size-limit.cjs

# Allowlist tracked dot-directories. The directory itself plus all
# non-dotfile contents (workflow YAMLs, husky hooks, etc.). Dotfiles
# inside (e.g. `.husky/.gitignore`) are covered by the file allowlist above.
!.github
!.github/**
!.husky
!.husky/**

test-results
