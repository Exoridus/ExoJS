#!/usr/bin/env sh
# Pre-push verification.
#
# Branch pushes:  `verify:quick` — the fast static CI-parity gates that most
#                 often pass locally but fail on CI: typecheck (core + guides +
#                 examples + extension packages), lint:all, format:check, and
#                 docs:api:check (the API-doc sync gate). No test/build here so
#                 the hook stays fast enough not to be bypassed; run the full
#                 local parity with `pnpm verify:ci` (adds the test suite). CI
#                 still runs test + browser + package-build + site.
# Tag pushes:     full `verify:release` (mirrors CI's verify job, including
#                 verify:exports + npm pack --dry-run) so a release tag is
#                 never published until the same checks CI runs have all
#                 passed locally.
#
# Refs being pushed are read from stdin in the format:
#   <local_ref> <local_sha> <remote_ref> <remote_sha>
is_tag_push=0
is_branch_push=0
null_sha="0000000000000000000000000000000000000000"

while read local_ref local_sha remote_ref remote_sha; do
    # Deletions carry the null SHA — nothing to verify when removing a ref.
    [ "$local_sha" = "$null_sha" ] && continue
    case "$remote_ref" in
        refs/tags/*) is_tag_push=1 ;;
        *)           is_branch_push=1 ;;
    esac
done

if [ "$is_tag_push" = "1" ]; then
    echo "[pre-push] tag push detected — running full release verification"
    npm run verify:release || exit 1
elif [ "$is_branch_push" = "1" ]; then
    echo "[pre-push] running verify:quick (static CI-parity gates)"
    npm run verify:quick || exit 1
fi
